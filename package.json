{
  "name": "my-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ./scripts/clean-next-dev.mjs",
    "dev": "next dev",
    "dev:clean": "node ./scripts/clean-next-dev.mjs && next dev",
    "build": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "build:safe": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "@types/qrcode": "^1.5.6",
    "marked": "^17.0.4",
    "next": "14.2.25",
    "qrcode": "^1.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.25",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
